{
  "dashboard": {
    "title": "AWS Cost Optimization Dashboard",
    "tags": ["cost", "finops", "aws"],
    "timezone": "Asia/Jakarta",
    "panels": [
      {
        "id": 1,
        "title": "Total Monthly Cost",
        "type": "stat",
        "targets": [
          {
            "refId": "A",
            "dimensions": {},
            "metricName": "EstimatedCharges",
            "namespace": "AWS/Billing",
            "period": "",
            "region": "us-east-1",
            "statistics": ["Maximum"]
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Cost by Service (Last 30 Days)",
        "type": "piechart",
        "targets": [
          {
            "refId": "B",
            "namespace": "AWS/Billing",
            "metricName": "EstimatedCharges",
            "dimensions": {"ServiceName": "*"}
          }
        ],
        "gridPos": {"h": 8, "w": 10, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Daily Cost Trend",
        "type": "graph",
        "targets": [
          {
            "refId": "C",
            "namespace": "AWS/Billing",
            "metricName": "EstimatedCharges",
            "statistics": ["Maximum"],
            "period": "86400"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
      },
      {
        "id": 4,
        "title": "EC2 Running Instances by Environment",
        "type": "table",
        "targets": [
          {
            "refId": "D",
            "queryType": "cloudwatch",
            "dimensions": {"Environment": "*"}
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "Unattached EBS Volumes",
        "type": "stat",
        "targets": [
          {
            "refId": "E",
            "metricName": "UnattachedVolumes",
            "namespace": "CustomMetrics"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8}
      },
      {
        "id": 6,
        "title": "Unused Elastic IPs",
        "type": "stat",
        "targets": [
          {
            "refId": "F",
            "metricName": "UnusedEIPs",
            "namespace": "CustomMetrics"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8}
      },
      {
        "id": 7,
        "title": "Estimated Monthly Savings",
        "type": "stat",
        "targets": [
          {
            "refId": "G",
            "metricName": "PotentialSavings",
            "namespace": "CustomMetrics"
          }
        ],
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"value": 0, "color": "red"},
            {"value": 1000, "color": "yellow"},
            {"value": 5000, "color": "green"}
          ]
        },
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 12}
      },
      {
        "id": 8,
        "title": "Cost per Team",
        "type": "bargauge",
        "targets": [
          {
            "refId": "H",
            "dimensions": {"Owner": "*"}
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      }
    ],
    "refresh": "5m",
    "schemaVersion": 30,
    "version": 1
  }
}
